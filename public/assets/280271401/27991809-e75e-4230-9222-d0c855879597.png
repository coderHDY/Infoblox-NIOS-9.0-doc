        <mxCell id="OPD4yn9kI0wNF1QHA7Qc-5" value="&lt;span&gt;When the NIOS appliance&lt;br&gt;receives the DHCPDISCOVER&lt;br&gt;message, it checks its record&lt;br&gt;of IP addresses and selects an&lt;br&gt;IP address for lease.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="354" y="136" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="OPD4yn9kI0wNF1QHA7Qc-6" value="&lt;span&gt;The appliance sends the&lt;br&gt;configured number of pings&lt;br&gt;to the selected IP address.&lt;br&gt;The appliance receives a&lt;br&gt;reply, indicating that the IP&lt;br&gt;address is in use.&lt;br&gt;&lt;br&gt;The appliance marks the lease &lt;br&gt;status of the&amp;nbsp;IP address as &lt;br&gt;Abandoned and&amp;nbsp;discards the &lt;br&gt;DISCOVER packet.&lt;br&gt;&lt;br&gt;&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="354" y="243" width="180" height="160" as="geometry" />
        </mxCell>
        <mxCell id="OPD4yn9kI0wNF1QHA7Qc-7" value="&lt;span&gt;The appliance selects another&lt;br&gt;IP address and sends it the&lt;br&gt;configured number of pings.&lt;br&gt;&lt;br&gt;The appliance does not receive&lt;br&gt;a response within the specified&lt;br&gt;timeout, and assumes the&lt;br&gt;address is not in use.&lt;br&gt;&lt;br&gt;Note that if the client broadcasts &lt;br&gt;DHCPDISCOVER messages at &lt;br&gt;less than 1 minute interval, the &lt;br&gt;appliance will not service them.&lt;br&gt;&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="347" y="497" width="190" height="170" as="geometry" />
        </mxCell>
        <mxCell id="OPD4yn9kI0wNF1QHA7Qc-8" value="&lt;span&gt;The appliance sends the client&lt;br&gt;a DHCPOFFER message with&lt;br&gt;the selected IP address.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="352" y="719" width="180" height="40" as="geometry" />
        </mxCell>
