        <mxCell id="0Rhv453rB2OEIdFgPjHd-7" value="&lt;span&gt;TCP Connection&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=center;verticalAlign=top;spacingTop=-4;fontStyle=1" vertex="1" parent="1">
