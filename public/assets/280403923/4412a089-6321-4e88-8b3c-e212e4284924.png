        <mxCell id="0Rhv453rB2OEIdFgPjHd-1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#636363,#959595);" vertex="1" parent="1">
          <mxGeometry x="20" y="30" width="740" height="362" as="geometry" />
        </mxCell>
        <mxCell id="0Rhv453rB2OEIdFgPjHd-2" value="&lt;span&gt;When a host broadcasts a&lt;br&gt;DHCPDISCOVER&lt;br&gt;message, it includes its&lt;br&gt;MAC address.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="67" y="46" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="0Rhv453rB2OEIdFgPjHd-3" value="&lt;span&gt;Both servers receive the&lt;br&gt;DHCPDISCOVER message.&lt;br&gt;Each server performs a hash on&lt;br&gt;the MAC address, and the result&lt;br&gt;is 250.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="573" y="41" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="0Rhv453rB2OEIdFgPjHd-4" value="&lt;span&gt;The load balancing split is 128.&lt;br&gt;Since the hash result is between&lt;br&gt;128 and 255, the secondary&lt;br&gt;server responds to the host and&lt;br&gt;allocates the IP address to the host.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="157" y="308" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="0Rhv453rB2OEIdFgPjHd-5" value="&lt;span&gt;Router&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=center;verticalAlign=top;spacingTop=-4;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="236" y="208" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="0Rhv453rB2OEIdFgPjHd-6" value="&lt;span&gt;Primary Server&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=center;verticalAlign=top;spacingTop=-4;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="418" y="40" width="100" height="20" as="geometry" />
