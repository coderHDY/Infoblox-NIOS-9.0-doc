        <mxCell id="ZEef7nP4q6Xr5N3h7Qr6-16" parent="1" style="text;strokeColor=default;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacingLeft=3;spacingRight=3;fontSize=11;" value="When remote admin accounts are not in an admin group (or in a group whose name does not match that of a local group), the NIOS appliance applies the default admin group permissions and properties (if configured)." vertex="1">
          <mxGeometry height="105" width="190" x="740" y="180" as="geometry" />
        </mxCell>
        <mxCell id="ZEef7nP4q6Xr5N3h7Qr6-17" parent="1" style="text;strokeColor=default;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacingLeft=3;spacingRight=3;fontSize=11;" value="When admin accounts are in an admin group that matches a group configured locally, the appliance selects the first group (based on remote admin policy) and applies the permissions and properties to the admin belonging to that group." vertex="1">
