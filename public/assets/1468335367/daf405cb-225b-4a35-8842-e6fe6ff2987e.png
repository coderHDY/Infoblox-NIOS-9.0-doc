        <mxCell id="Qcul34wtrQMzJg_jMcqT-24" value="The private network (10.1.1.0/24) is reserved for Grid communications between the Multi-Grid Master and all Master Grid members, and for appliance management between the management system and the Multi-Grid Master." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
