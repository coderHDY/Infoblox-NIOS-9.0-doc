        <mxCell id="Qcul34wtrQMzJg_jMcqT-27" value="They connect to the public network through their LAN and HA ports (using a VIP)." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
