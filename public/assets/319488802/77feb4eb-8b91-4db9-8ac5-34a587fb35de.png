        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-7" value="" style="shape=image;verticalLabelPosition=bottom;verticalAlign=top;imageAspect=0;aspect=fixed;image=data:image/png," parent="1" vertex="1">
          <mxGeometry x="-804.5" y="-720" width="40.58" height="40" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-8" value="Connect your management system to a switch and set its IP address to 192.168.1.3." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-745" y="-1066" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-9" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="-224.99999999999997" y="-807" width="99.17" height="40" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-10" value="Connect Node 1 to the switch, log in to its default IP address (192.168.1.2), check that a Grid license is installed, and configure the following:&lt;div&gt;&lt;ul&gt;&lt;li&gt;VIP address, netmask, gateway&lt;/li&gt;&lt;li&gt;Hostname&lt;/li&gt;&lt;li&gt;HA and LAN1 addresses of Node 1&lt;/li&gt;&lt;li&gt;HA and LAN1 addresses of Node 2&lt;/li&gt;&lt;li&gt;VRID (virtual router ID)&lt;/li&gt;&lt;li&gt;NTP settings&lt;/li&gt;&lt;li&gt;Grid name&lt;/li&gt;&lt;li&gt;Shared secret&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-759.5" y="-720" width="265" height="200" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-11" value="After you configure Node 1, it listens for three seconds for VRRP advertisements containing its VRID number. When it does not receive any, it assumes the active role in the HA pair and starts sending advertisements." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-759.5" y="-510" width="265" height="80" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-12" value="" style="shape=image;verticalLabelPosition=bottom;verticalAlign=top;imageAspect=0;aspect=fixed;image=data:image/png," parent="1" vertex="1">
          <mxGeometry x="-804.5" y="-510" width="40.58" height="40" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-13" value="&lt;font style=&quot;&quot;&gt;For more information about VRRP advertisements, see the &lt;i&gt;VRRP Advertisements&lt;/i&gt; page.&lt;/font&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;labelBorderColor=none;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="-759.5" y="-420" width="195" height="50" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-14" value="" style="shape=image;verticalLabelPosition=bottom;verticalAlign=top;imageAspect=0;aspect=fixed;image=data:image/png," parent="1" vertex="1">
          <mxGeometry x="-354.5" y="-720" width="40.58" height="40" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-15" value="Connect Node 2 to the switch, log in to its default IP address (192.168.1.2), check that a Grid license is installed, and configure the following:&lt;div&gt;&lt;ul&gt;&lt;li&gt;LAN address, netmask, gateway&lt;/li&gt;&lt;li&gt;Hostname&lt;/li&gt;&lt;li&gt;Grid name&lt;/li&gt;&lt;li&gt;Shared secret&lt;/li&gt;&lt;li&gt;Join the node using the VIP address&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-309.5" y="-720" width="265" height="140" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-16" value="Note: Since you did not set the VRID for Node 2, it cannot listen for VRRP advertisements yet. It learns its VRID after it joins the Grid and downloads the database from Node 1. Then, when Node 2 receives an advertisement containing its VRID from Node 1, it assumes the passive role in the HA pair." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;labelBorderColor=none;spacingLeft=1;spacingBottom=2;spacingTop=1;spacingRight=4;spacing=2;" parent="1" vertex="1">
          <mxGeometry x="-309.5" y="-570" width="255" height="130" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-17" value="After you configure Node 2, it contacts the VIP address on Node 1 and initiates a mutual authentication of the node using the shared secret. The nodes then construct an encrypted VPN tunnel to secure Grid communications." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-307.92" y="-430" width="263.42" height="80" as="geometry" />
        </mxCell>
        <mxCell id="O7CAMVfddxVe0MeYyHHP-18" value="" style="shape=image;verticalLabelPosition=bottom;verticalAlign=top;imageAspect=0;aspect=fixed;image=data:image/png," parent="1" vertex="1">
          <mxGeometry x="-354.5" y="-427" width="40" height="39.43" as="geometry" />
        </mxCell>
