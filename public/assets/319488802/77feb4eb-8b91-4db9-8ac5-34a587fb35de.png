        <mxCell id="O7CAMVfddxVe0MeYyHHP-4" value="Management System" style="text;html=1;resizable=0;points=[];autosize=1;align=center;verticalAlign=top;spacingTop=-4;fontStyle=1;fontColor=light-dark(#1db14c, #ededed);" parent="1" vertex="1">
