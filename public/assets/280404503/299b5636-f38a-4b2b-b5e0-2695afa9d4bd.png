        </mxCell>
        <mxCell id="114" value="&lt;span&gt;* Do not start DHCP&lt;br&gt;services when&lt;br&gt;configuring members&lt;br&gt;until the configuration&lt;br&gt;is complete.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;fontFamily=Helvetica;fontSize=12;" parent="1" vertex="1">
