        <mxCell id="113" value="&lt;span&gt;Do you want to&lt;br&gt;configure&lt;br&gt;member-level DHCP&lt;br&gt;properties?&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=center;verticalAlign=top;spacingTop=-4;fontFamily=Helvetica;fontSize=12;" parent="1" vertex="1">
