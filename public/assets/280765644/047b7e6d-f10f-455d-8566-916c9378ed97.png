        <mxCell id="-u-hTiwVueqbjvWz0cXG-89" value="VRRP Advertisements" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontColor=light-dark(#7097fa, #ededed);fontSize=13;" vertex="1" parent="1">
