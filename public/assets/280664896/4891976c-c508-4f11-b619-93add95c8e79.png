        <mxCell id="cRtKDf7dVKyj0_DRojG7-4" value="" style="whiteSpace=wrap;html=1;fillColor=light-dark(#fdc9cb, #36210a);strokeColor=none;rounded=1;" vertex="1" parent="1">
