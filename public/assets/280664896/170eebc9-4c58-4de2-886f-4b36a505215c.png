        <mxCell id="PHUmP3C1KNNhUk2zHhpx-27" value="&lt;span&gt;Update for forward-mapping zone example.com&lt;br&gt;&lt;br&gt;A record: jsmith-xp 10.1.2.90&lt;br&gt;&lt;br&gt;TXT record: jsmith-xp&lt;br&gt;“31995a5ea0681ee5d2f6e06ad0d0477e84”&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="1443.73" y="49" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-28" value="&lt;span&gt;Update for reverse-mapping zone&lt;br&gt;2.1.10-in-addr.arpa&lt;br&gt;&lt;br&gt;PTR record: 90 – jsmith-xp.exam100.com&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="1443.73" y="163" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-29" value="" style="whiteSpace=wrap;html=1;align=center;fillColor=light-dark(#FFFFFF,#392F3F);strokeColor=light-dark(#729CFD,#EDEDED);gradientColor=light-dark(#BFD0F9,#EDEDED);gradientDirection=west;" vertex="1" parent="1">
          <mxGeometry x="1561.73" y="144" width="30" height="10" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-30" value="&lt;span&gt;DHCP ACK&lt;br&gt;&lt;br&gt;IP Address: 10.1.2.90&lt;br&gt;&lt;br&gt;Option: 15, domain name:&amp;nbsp;&lt;/span&gt;example&lt;span&gt;.com&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="1192.73" y="483" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-31" value="" style="ellipse;whiteSpace=wrap;html=1;align=center;fillColor=light-dark(#FFFFFF,#392F3F);strokeColor=light-dark(#36E4ED,#392F3F);gradientColor=light-dark(#dcf8ff, #ededed);" vertex="1" parent="1">
          <mxGeometry x="1171.73" y="576" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-32" value="DHCP Range&lt;br&gt;10.1.2.10 &lt;br&gt;10.1.2.100" style="ellipse;whiteSpace=wrap;html=1;align=center;dashed=1;fillColor=light-dark(#FFFFFF,#392F3F);strokeColor=light-dark(#36E4ED,#392F3F);gradientColor=light-dark(#dcf8ff, #ededed);" vertex="1" parent="1">
          <mxGeometry x="1188.73" y="596" width="123" height="60" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-33" value="Network&lt;br&gt;10.1.2.0/24" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="1324.73" y="611" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-34" value="&lt;span&gt;When the update reaches the&lt;br&gt;primary server, it updates its&lt;br&gt;zone data, increases the&lt;br&gt;&lt;/span&gt;example&lt;span&gt;.com zone serial&lt;br&gt;number, and sends a NOTIFY&lt;br&gt;to ns2.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="1667.73" y="478" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-35" value="&lt;span&gt;When the secondary server&lt;br&gt;receives the NOTIFY, it checks&lt;br&gt;if ns1 has a higher serial&lt;br&gt;number for&amp;nbsp;&lt;/span&gt;example&lt;span&gt;.com.&lt;br&gt;&lt;br&gt;Because the&amp;nbsp;&lt;/span&gt;example&lt;span&gt;.com serial&lt;br&gt;number on ns1 is higher, ns2&lt;br&gt;requests an incremental zone&lt;br&gt;transfer (IXFR).&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="1800.73" y="573" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-36" value="&lt;span&gt;ns1 sends the changed&lt;br&gt;zone data to ns2.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="1664.73" y="722" width="150" height="30" as="geometry" />
        </mxCell>
        <mxCell id="PHUmP3C1KNNhUk2zHhpx-37" value="&lt;b&gt;Note&lt;/b&gt;: The DHCP server asynchronously updates DNS for a&lt;br&gt;particular lease and sends the DHCP ACK to the client&lt;br&gt;requesting the lease. If the DNS update is unsuccessful,&lt;br&gt;the DHCP client still gets its lease. The DHCP server then&lt;br&gt;continues its DNS update attempts at predefined or&lt;br&gt;user-defined intervals." style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
          <mxGeometry x="1166.73" y="687" width="340" height="90" as="geometry" />
        </mxCell>
