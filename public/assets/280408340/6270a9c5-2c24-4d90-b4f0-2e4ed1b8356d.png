  <diagram id="0" name="Page-1">
    <mxGraphModel dx="2634" dy="1088" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="141" value="" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="-760" y="-40" width="880" height="160" as="geometry" />
        </mxCell>
        <mxCell id="146" value="" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="-760" y="130" width="880" height="200" as="geometry" />
        </mxCell>
        <mxCell id="147" value="" style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="-760" y="340" width="880" height="80" as="geometry" />
        </mxCell>
        <mxCell id="3" value="A user makes an HTTPS connection to the NIOS appliance&lt;br&gt;and sends a account name and password." style="text;html=1;" parent="1" vertex="1">
          <mxGeometry x="-710" y="-30" width="340" height="30" as="geometry" />
        </mxCell>
        <mxCell id="4" value="The appliance checks &lt;span&gt;the authentication policy &lt;br&gt;to determine which authentication service to use.&lt;br&gt;The authentication policy specifies an AD authentication service.&lt;/span&gt;" style="text;html=1;" parent="1" vertex="1">
          <mxGeometry x="-240" y="-40" width="480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="5" value="The appliance &lt;span&gt;sends an authentication request to the first &lt;br&gt;domain controller in the AD server group. The appliance also&lt;br&gt;requests the group membership information of the admin.&lt;/span&gt;" style="text;html=1;" parent="1" vertex="1">
          <mxGeometry x="-240" y="25" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="6" value="&lt;span&gt;Authentication is successful. The domain controller successfully&lt;br&gt;authenticates the admin user. The group membership &lt;br&gt;information for the administrator is sent to the appliance.&lt;br&gt;The first group in the list that matches the groups returned&lt;br&gt;by the domain controller is assigned to the admin,&lt;br&gt;along with the associated permissions after that admin logs in.&lt;/span&gt;" style="text;html=1;" parent="1" vertex="1">
          <mxGeometry x="-240" y="145" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="8" value="The appliance lets the user log in and applies the authorization profile.&lt;br&gt;&lt;br&gt;&lt;span&gt;The appliance grants all permissions specific to the administrator &lt;br&gt;based on the group membership sent from the domain controller &lt;br&gt;associated with the admin account. If there is no group&lt;br&gt;membership information for the admin, the default group is assigned &lt;br&gt;(if configured).&lt;/span&gt;" style="text;html=1;" parent="1" vertex="1">
          <mxGeometry x="-720" y="145" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="9" value="The appliance does not allow the userto log in." style="text;html=1;" parent="1" vertex="1">
          <mxGeometry x="-720" y="360" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="10" value="If the AD server rejects the authentication request, &lt;br&gt;it sends back an Access-Reject packet." style="text;html=1;" parent="1" vertex="1">
          <mxGeometry x="-240" y="350" width="540" height="30" as="geometry" />
        </mxCell>
        <mxCell id="138" value="" style="shape=image;verticalLabelPosition=bottom;verticalAlign=top;imageAspect=0;aspect=fixed;image=data:image/png," parent="1" vertex="1">
