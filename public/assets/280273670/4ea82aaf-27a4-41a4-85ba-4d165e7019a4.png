        <mxCell id="Uuh1Thq5TfoNFALKqxXo-9" value="&lt;span&gt;The Grid Master sends&lt;br&gt;discovery requests to the&lt;br&gt;Grid member that runs the&lt;br&gt;discovery tasks.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
