        </mxCell>
        <mxCell id="gG8RdTQuM4OR13oY_M8M-6" value="&lt;span&gt;The reporting server collects&lt;br&gt;data about the remote clients&lt;br&gt;and generates reports you can&lt;br&gt;use to monitor the devices.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
          <mxGeometry x="155" y="340" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gG8RdTQuM4OR13oY_M8M-7" value="&lt;span&gt;A remote client requests for a lease. Its&lt;br&gt;option number sequence matches the&lt;br&gt;DHCP fingerprint of an Android phone.&lt;br&gt;Based on the DHCP fingerprint filter criteria,&lt;br&gt;the appliance grants a lease to the&lt;br&gt;requesting client.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
          <mxGeometry x="342" y="237" width="250" height="90" as="geometry" />
