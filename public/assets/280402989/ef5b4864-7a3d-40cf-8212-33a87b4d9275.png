        <mxCell id="gG8RdTQuM4OR13oY_M8M-4" value="&lt;span&gt;A remote client requests for a lease. Its&lt;br&gt;vendor ID matches the DHCP fingerprint of&lt;br&gt;a gaming console. Based on the DHCP&lt;br&gt;fingerprint filter criteria, the appliance&lt;br&gt;denies a lease to the requesting client.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
          <mxGeometry x="144" y="27" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="gG8RdTQuM4OR13oY_M8M-5" value="&lt;span&gt;Standard and&lt;br&gt;custom DHCP&lt;br&gt;fingerprints cached&lt;br&gt;in NIOS database.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
