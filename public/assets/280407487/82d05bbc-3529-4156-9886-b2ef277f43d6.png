        </mxCell>
        <mxCell id="IilbE9co8Z_d94cJzwjW-36" value="The Cloud Platform Appliance processes the API request. If it is not authoritative for objects referenced in the request, it proxies the request to the Grid Master or another Cloud Platform Appliance, depending on the authority delegation." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
