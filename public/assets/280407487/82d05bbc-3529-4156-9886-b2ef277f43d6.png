        <mxCell id="IilbE9co8Z_d94cJzwjW-34" value="The cloud adapter sends the corresponding cloud API request to the Cloud Platform Appliance through the cloud API service." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
