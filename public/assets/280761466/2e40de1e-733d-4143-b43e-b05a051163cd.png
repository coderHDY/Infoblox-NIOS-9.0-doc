        <mxCell id="-ebe1oBjaMvfSabAEkVk-25" value="Remote Host&lt;br&gt;DHCP Client" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="1170.0000000000002" y="205.24" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="-ebe1oBjaMvfSabAEkVk-26" value="Sample client ID types:&lt;div&gt;&lt;ul&gt;&lt;li&gt;Unit-slot-port number of network access server&lt;/li&gt;&lt;li&gt;ATM virtual circuit number&lt;/li&gt;&lt;li&gt;Cable data virtual circuit number&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;labelPosition=center;verticalLabelPosition=middle;" parent="1" vertex="1">
          <mxGeometry x="1200.8600000000001" y="30" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="-ebe1oBjaMvfSabAEkVk-27" value="Sample remote ID types:&lt;div&gt;&lt;ul&gt;&lt;li&gt;User name (as prompted by network access server)&lt;/li&gt;&lt;li&gt;Remote caller ATM address&lt;/li&gt;&lt;li&gt;Modem ID for a cable data modem&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;labelPosition=center;verticalLabelPosition=middle;" parent="1" vertex="1">
          <mxGeometry x="1477.78" y="30" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="-ebe1oBjaMvfSabAEkVk-28" value="The Remote ID is set on the relay agent to identify the remote host." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;labelPosition=center;verticalLabelPosition=middle;" parent="1" vertex="1">
          <mxGeometry x="1275.8600000000001" y="130" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="-ebe1oBjaMvfSabAEkVk-29" value="The NIOS appliance checks for a match between the remote and circuit identifiers in the address request and its filters for address ranges. When it finds a match, it assigns the DHCP client an address from the address range." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;labelPosition=center;verticalLabelPosition=middle;" parent="1" vertex="1">
          <mxGeometry x="1540.8600000000001" y="370" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="-ebe1oBjaMvfSabAEkVk-30" value="The relay agent adds option 82 data to DHCPDISCOVER and DHCPREQUEST messages that it receives from the DHCP client." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;labelPosition=center;verticalLabelPosition=middle;" parent="1" vertex="1">
          <mxGeometry x="1150" y="420" width="263.42" height="90" as="geometry" />
        </mxCell>
        <mxCell id="-ebe1oBjaMvfSabAEkVk-31" value="DHCP Option 82 suboptions can specify a remote ID for the DHCP client and a circuit ID for the connection between the client and the access point." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;labelPosition=center;verticalLabelPosition=middle;" parent="1" vertex="1">
          <mxGeometry x="1150" y="471" width="276.71" height="90" as="geometry" />
        </mxCell>
