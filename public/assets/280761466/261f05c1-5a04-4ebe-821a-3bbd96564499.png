        <mxCell id="9" value="Internet" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
          <mxGeometry x="421" y="219" width="50" height="20" as="geometry" />
        </mxCell>
        <mxCell id="10" value="&lt;span&gt;The relay agent adds option 82 data to&lt;br&gt;DHCPDISCOVER and DHCPREQUEST&lt;br&gt;messages that it receives from the DHCP client.&lt;br&gt;&lt;br&gt;DHCP Option 82 suboptions can specify a&lt;br&gt;remote ID for the DHCP client and a circuit ID&lt;br&gt;for the connection between the client and the&lt;br&gt;access point.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
          <mxGeometry x="-48" y="376" width="270" height="110" as="geometry" />
        </mxCell>
        <mxCell id="11" value="&lt;span&gt;The NIOS appliance checks for a&lt;br&gt;match between the remote and&lt;br&gt;circuit identifiers in the address&lt;br&gt;request and its filters for address&lt;br&gt;ranges. When it finds a match, it&lt;br&gt;assigns the DHCP client an&lt;br&gt;address from that address range.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
          <mxGeometry x="360" y="376" width="190" height="100" as="geometry" />
        </mxCell>
        <mxCell id="13" value="&lt;span&gt;Remote Host&lt;br&gt;DHCP Client&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
