        <mxCell id="3" value="&lt;span&gt;Sample client ID types:&lt;br&gt;• Unit-slot-port number of network&lt;br&gt;access server&lt;br&gt;• ATM virtual circuit number&lt;br&gt;• Cable data virtual circuit number&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
          <mxGeometry x="-54" y="-40" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="4" value="&lt;span&gt;Sample remote ID types:&lt;br&gt;• User name (as prompted by&lt;br&gt;network access server)&lt;br&gt;• Remote caller ATM address&lt;br&gt;• Modem ID for a cable data modem&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
          <mxGeometry x="160" y="-40" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="5" value="&lt;span&gt;The Remote ID is&lt;br&gt;set on the relay&lt;br&gt;agent to identify&lt;br&gt;the remote host.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1">
