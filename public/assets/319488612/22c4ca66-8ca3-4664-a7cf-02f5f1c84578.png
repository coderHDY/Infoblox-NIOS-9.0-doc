        <mxCell id="cLyO6bI1JeVqG7F6bkEs-75" value="The Grid members serve time to devices on their networks. Each member uses symmetric key encryption to secure NTP messages. Each member also has an access control list that defines which appliances can access the time services. When a client that is not on the list tries to access an appliance functioning as an NTP server, the appliances ignores the message." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="751.6199999999999" y="171" width="310" height="125" as="geometry" />
        </mxCell>
        <mxCell id="cLyO6bI1JeVqG7F6bkEs-76" value="The Grid Master uses three public NTP servers to calibrate its clock to the correct time. It uses symmetric key cryptography to secure NTP messages.&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;The Grid Master serves time to the Grid members. All NTP communications with the Grid go through the encrypted VPN tunnels.&lt;/div&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="55.8900000000001" y="261" width="240" height="122" as="geometry" />
        </mxCell>
        <mxCell id="cLyO6bI1JeVqG7F6bkEs-77" value="&lt;b&gt;Client&lt;br&gt;(Not on List)&lt;/b&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="972.0999999999999" y="311" width="123.67" height="30" as="geometry" />
        </mxCell>
