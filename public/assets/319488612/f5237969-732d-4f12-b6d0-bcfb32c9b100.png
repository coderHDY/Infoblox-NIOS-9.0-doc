        <mxCell id="1mA8t0R2fVpfdA24CtiX-44" value="The Grid Master serves time to Grid Member 1. All NTP communications with the Grid go through encrypted VPN tunnels." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
