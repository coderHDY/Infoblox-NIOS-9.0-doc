        <mxCell id="K1otuij_6eJ1Y0YtBza0-10" value="NTP server administrator sends the secret key information to the NTP client administrator, who adds the key to the NTP client." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
