        <mxCell id="Mi-NtCUtcsx6chmO0AA8-42" value="Grid Member 2 synchronizes its clock with an external NTP server. It also functions as a stratum-2 NTP server to external devices on its network." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="830" y="440" width="180" height="62" as="geometry" />
        </mxCell>
        <mxCell id="Mi-NtCUtcsx6chmO0AA8-43" value="Stratum-1 NTP servers use reference clocks to synchronize their time to UTC (Coordinated Universal Time).&amp;nbsp;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="23" y="272" width="170" height="53" as="geometry" />
        </mxCell>
        <mxCell id="Mi-NtCUtcsx6chmO0AA8-44" value="In this example, the Grid Master–as an NTP client–synchonrizes its time with stratum-1 NTP servers. The Grid Master also functions as a stratum-2 NTP server to Grid Member 1. NTP messages between the Grid Master and Grid Member 1 go through encrypted VPN tunnels." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="20.299999999999955" y="436" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Mi-NtCUtcsx6chmO0AA8-45" value="As an NTP client, Grid Member 1 synchronizes its clock with the Grid Master. It also functions as a stratum-3 NTP server to external devices on its network." style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
