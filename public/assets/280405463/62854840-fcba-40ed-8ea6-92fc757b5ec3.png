        <mxCell id="gFRr6E1wl52cWDbFEIfl-7" value="&lt;span&gt;The NIOS appliance removes zone B,&lt;br&gt;subzone C, and all their resource records.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" vertex="1" parent="1">
