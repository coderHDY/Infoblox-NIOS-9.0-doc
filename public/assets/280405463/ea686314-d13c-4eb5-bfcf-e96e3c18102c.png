        <mxCell id="pCPi4XRwCNF6ACsBISmz-3" value="&lt;span&gt;… reparent its subzones.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=center;verticalAlign=top;spacingTop=-4;fontStyle=1" vertex="1" parent="1">
