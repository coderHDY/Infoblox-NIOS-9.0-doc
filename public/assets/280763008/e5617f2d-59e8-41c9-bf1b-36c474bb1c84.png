s2.arrow;dy=0.5;dx=43.87;notch=0;" parent="1" vertex="1"><mxGeometry x="180" y="270" width="98" height="62" as="geometry"/></mxCell><mxCell id="19" value="" style="whiteSpace=wrap;html=1;direction=south;fillColor=#f5f5f5;strokeColor=none;" parent="1" vertex="1"><mxGeometry x="335" y="278" width="110" height="120" as="geometry"/></mxCell><mxCell id="2" value="" style="shape=image;imageAspect=0;aspect=fixed;verticalLabelPosition=bottom;verticalAlign=top;image=https://infoblox-docs.atlassian.net/wiki/download/attachments/22251663/worddav704b23f70ef566e75fae09268b62cbd5.png;;" parent="1" vertex="1"><mxGeometry x="358" y="306" width="64" height="69" as="geometry"/></mxCell><mxCell id="20" value="&lt;span&gt;The appliance&lt;br&gt;reparents the&lt;br&gt;subzones B1 and B2&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1"><mxGeometry x="175" y="400" width="130" height="40" as="geometry"/></mxCell><mxCell id="21" value="&lt;span&gt;Restore Zone B&lt;br&gt;from the &lt;/span&gt;&lt;span&gt;Recycle&lt;br&gt;Bin&lt;/span&gt;&lt;span&gt;. The appliance&lt;br&gt;reparents subzones&lt;br&gt;B1 and B2 back to&lt;br&gt;Zone B.&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1"><mxGeometry x="350" y="126" width="130" height="90" as="geometry"/></mxCell><mxCell id="22" value="3" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=none;" parent="1" vertex="1"><mxGeometry x="325" y="128" width="20" height="20" as="geometry"/></mxCell><mxCell id="24" value="" style="endArrow=none;html=1;strokeColor=#D6D6D6;" parent="1" edge="1"><mxGeometry width="50" height="50" relative="1" as="geometry"><mxPoint x="-210" y="425" as="sourcePoint"/><mxPoint x="-210" y="195" as="targetPoint"/></mxGeometry></mxCell><mxCell id="25" value="" style="endArrow=none;html=1;strokeColor=#D6D6D6;" parent="1" edge="1"><mxGeometry width="50" hei