<mxfile userAgent="Mozilla/5.0 (Windows NT 10.0; WOW64; rv:53.0) Gecko/20100101 Firefox/53.0" version="6.6.3" editor="www.draw.io" type="atlas"><mxAtlasLibraries/><diagram name="Page-1"><mxGraphModel dx="1608" dy="663" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" background="#ffffff" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="3" value="Zone A" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=none;" parent="1" vertex="1"><mxGeometry x="-280" y="156" width="140" height="60" as="geometry"/></mxCell><mxCell id="4" value="&lt;span&gt;You import&lt;br&gt;subzones x and y&lt;br&gt;to Zone B&lt;/span&gt;" style="text;html=1;resizable=0;points=[];autosize=1;align=left;verticalAlign=top;spacingTop=-4;" parent="1" vertex="1"><mxGeometry x="-100" y="174" width="110" height="40" as="geometry"/></mxCell><mxCell id="5" value="Source Zone B" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e1d5e7;strokeColor=none;" parent="1" vertex="1"><mxGeometry x="-280" y="280" width="140" height="60" as="geometry"/></mxCell><mxCell id="6" value="Sub x" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e1d5e7;strokeColor=none;" parent="1" vertex="1"><mxGeometry x="-245" y="400" width="70" height="30" as="geometry"/></mxCell><mxCell id="7" value="Sub y" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e1d5e7;strokeColor=none;" parent="1" vertex="1"><mxGeometry x="-245" y="430" width="70" height="30" as="geometry"/></mxCell><mxCell id="8" value="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=none;" parent="1" vertex="1"><mxGeometry x="-123" y="169" width="20" height="20" as="geometry"/></mxCell><mxCell id="9" value="Zone A" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=none;" parent="1" vertex="1"><mxGeometry x="10" y="156" width="140" height="60" as="geometry"/></mxCell><mxC